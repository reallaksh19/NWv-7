{
  "name": "news-weather-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://lakshman81-ai.github.io/News-Weather-App",
  "scripts": {
    "dev": "vite",
    "api": "python scripts/server.py",
    "build": "vite build",
    "benchmark": "node scripts/run_upahead_benchmarks.js",
    "test:upahead-smoke": "node scripts/test_upahead_classification_smoke.mjs",
    "test:market-snapshot": "node scripts/test_market_snapshot_integrity.mjs",
    "lint": "eslint .",
    "preview": "vite preview --open",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "test:insight-history": "node scripts/test_insight_history_integrity.mjs",
    "test:insight-digest": "node scripts/test_insight_digest_integrity.mjs",
    "benchmark:insight-dedup": "node benchmarks/insight/runWave4DedupBenchmark.mjs",
    "benchmark:insight-events": "node benchmarks/insight/runWave5EventClusterBenchmark.mjs",
    "benchmark:insight-anchors": "node benchmarks/insight/runWave6AnchorBenchmark.mjs",
    "benchmark:insight-angles": "node benchmarks/insight/runWave7AngleBenchmark.mjs",
    "benchmark:insight-ranking": "node benchmarks/insight/runWave8RankingBenchmark.mjs",
    "benchmark:insight": "node benchmarks/insight/runInsightBenchmarks.mjs",
    "test:insight": "node scripts/test_insight_all.mjs",
    "test:insight-static": "node scripts/test_insight_ci_static.mjs",
    "test:insight-contracts": "node scripts/test_insight_contract_schemas.mjs"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.0",
    "sentiment": "^5.0.2",
    "string-similarity": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.1.1",
    "globals": "^16.5.0",
    "node-fetch": "^3.3.2",
    "playwright": "^1.59.1",
    "vite": "^7.2.4"
  }
