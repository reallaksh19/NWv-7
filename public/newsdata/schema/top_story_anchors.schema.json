{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "sourceMode", "anchorPolicy", "anchors"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sourceMode": { "type": "string" },
    "anchorPolicy": {
      "type": "object",
      "required": [
        "usesUserVisibleFilteredTopStories", "usesReadSuppression",
        "usesViewCountSuppression", "usesCustomSortTopStories"
      ],
      "properties": {
        "usesUserVisibleFilteredTopStories": { "type": "boolean", "const": false },
        "usesReadSuppression": { "type": "boolean", "const": false },
        "usesViewCountSuppression": { "type": "boolean", "const": false },
        "usesCustomSortTopStories": { "type": "boolean", "const": false }
      }
    },
    "anchors": { "type": "array" }
  }
}
