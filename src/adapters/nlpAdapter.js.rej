+export async function extractVerbs(text) {
+    const verbs = [];
+    const lowerText = text.toLowerCase();
+    VERBS.forEach(verb => {
+        const regex = new RegExp(`\\b${verb}\\b`, 'g');
+        if (regex.test(lowerText)) verbs.push(verb);
+    });
+    return [...new Set(verbs)];
+}
+
