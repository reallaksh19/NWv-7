--- src/insight/src/ranking/ranking.ts	2026-04-17 17:30:00.000000000 +0000
+++ src/insight/src/ranking/ranking.ts	2026-04-17 19:04:19.532084543 +0000
@@ -103,7 +103,9 @@
   ).length;

   const recentAvg = (countNow + countMinus4) / 2;
