+                }
+            } catch (e) {
+                console.error('Incremental update failed:', e);
+            }
+        }, 5 * 60 * 1000);
+        return () => clearInterval(interval);
+    }, [result]);
+
+    const toggleExpand = useCallback((id) => {
+        setExpanded(prev => ({ ...prev, [id]: !prev[id] }));
